# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Nothing sensitive should ever live in source — it all comes from here.
#
# This file is for LOCAL DEV (Socket Mode, `npm run dev` / `npm run local`).
# The judge-facing deployment (API Gateway + Lambda) reads the same values
# from infra/terraform.tfvars instead — see infra/README.md.
# ---------------------------------------------------------------------------

# --- Slack Seed Bot -----------------------------------------------------------------
SLACK_SEED_BOT_TOKEN=xoxb-your-bot-token
# App-level token (xapp-...) with connections:write — required for Socket Mode.
SLACK_SEED_APP_TOKEN=xapp-your-app-token
# Signing secret (used if/when you move off Socket Mode to HTTP events).
SLACK_SEED_SIGNING_SECRET=your-signing-secret
# Channel to listen on for feedback (channel ID, e.g. C0123456789).

# --- Slack Finny Bot -----------------------------------------------------------------
# Used by BOTH entrypoints: Socket Mode locally (npm run dev) and the deployed
# Lambda receiver/worker (see infra/ — same token, passed as a Lambda env var
# via infra/terraform.tfvars instead of this file).
#
# Bot token (xoxb-...). Scopes needed: chat:write, reactions:write,
# channels:history, groups:history, app_mentions:read.
SLACK_BOT_TOKEN=xoxb-your-bot-token
# App-level token (xapp-...) with connections:write — Socket Mode ONLY. Not
# needed (or used) by the Lambda deployment, which uses SLACK_SIGNING_SECRET
# instead to verify requests over HTTP. See CLAUDE.md's "Two transports" note.
SLACK_APP_TOKEN=xapp-your-app-token
# Signing secret — verifies incoming HTTP requests really came from Slack.
# Required for the Lambda deployment; unused by Socket Mode.
SLACK_SIGNING_SECRET=your-signing-secret
# Channel to listen on for feedback (channel ID, e.g. C0123456789).
SLACK_FEEDBACK_CHANNEL=C0123456789
# Usergroup ID (starts with "S...") @-mentioned on the verdict card so a PM
# sees it even with the channel muted. Slack admin -> User Groups, or the
# usergroups.list API. Optional — omit to skip the mention.
SLACK_PRODUCT_OWNER_GROUP_ID=S0123456789
SLACK_MCP_USER_TOKEN=xoxp-your-user-token

# --- AWS / Bedrock ---------------------------------------------------------
AWS_REGION=us-east-1
# Use a named profile with Bedrock model access — do NOT use your AWS account
# root user. If Bedrock calls fail with a "use case details" error, that's a
# console-only fix (Bedrock → Model access), independent of everything else.
AWS_PROFILE=your-aws-profile
# NEVER hardcode a model id in source — read it from here. Must be an
# inference-profile-qualified id (e.g. us.anthropic.claude-sonnet-4-5-...) —
# bare model IDs are rejected for on-demand Bedrock invoke.
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# Set to "false" to make real Bedrock Converse calls instead of the stub.
BEDROCK_STUB=false
# Standard AWS creds are picked up by the SDK from the environment / profile.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- MCP servers (remote HTTP endpoints — do NOT assume localhost) ---------
# Your Zendesk MCP server.
ZENDESK_MCP_URL=https://your-zendesk-mcp.example.com/mcp
# Official Slack MCP server.
SLACK_MCP_URL=https://your-slack-mcp.example.com/mcp

# --- Sandbox seeding: Zendesk ----------------------------------------------
ZENDESK_SUBDOMAIN=examplesubdomain
ZENDESK_EMAIL=you@example.com
ZENDESK_API_TOKEN=your-zendesk-api-token
ZENDESK_MCP_TOKEN=<random>

# --- Sandbox seeding: Jira -------------------------------------------------
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=DEMO
