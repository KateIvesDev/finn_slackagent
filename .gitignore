# Secrets — never commit
.env
.env.local
.env.*.local

# Dependencies
node_modules/

# Build / cache
dist/
*.tsbuildinfo
.eslintcache
infra/build/

# Terraform (the .terraform.lock.hcl provider lockfile IS committed, like
# package-lock.json — only the local cache/state/secrets are ignored)
infra/**/.terraform/
infra/**/*.tfstate
infra/**/*.tfstate.*
infra/**/terraform.tfvars
infra/**/*.tfplan
infra/tfplan

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

.kate/
.claude/
memory